    <Property Name="DepartmentCode" Type="String" MaxLength="20" FixedLength="false" Unicode="true" Nullable="false" />
    <Property Name="Budget" Type="Decimal" Precision="15" Scale="2" Nullable="false" />
    <Property Name="ManagerID" Type="Int32" />
    <Property Name="CreatedDate" Type="DateTime" Precision="7" />
    <Property Name="ModifiedDate" Type="DateTime" Precision="7" />
    <NavigationProperty Name="Employee" Relationship="Self.FK_Departments_Manager" FromRole="Departments" ToRole="Employees" />
