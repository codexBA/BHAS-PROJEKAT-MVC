      </Dependent>
    </ReferentialConstraint>
  </Association>
  <Association Name="FK_ReportData_Regions">
    <End Role="Regions" Type="Self.Region" Multiplicity="0..1" />
    <End Role="ReportData" Type="Self.ReportData" Multiplicity="*" />
    <ReferentialConstraint>
