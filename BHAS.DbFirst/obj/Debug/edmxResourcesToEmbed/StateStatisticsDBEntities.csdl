    <Property Name="DataType" Type="String" MaxLength="50" FixedLength="false" Unicode="true" Nullable="false" />
    <Property Name="Value" Type="Decimal" Precision="18" Scale="2" />
    <Property Name="TextValue" Type="String" MaxLength="Max" FixedLength="false" Unicode="true" />
