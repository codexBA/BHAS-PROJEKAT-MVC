    <NavigationProperty Name="ReportDatas" Relationship="Self.FK_ReportData_Regions" FromRole="Regions" ToRole="ReportData" />
  </EntityType>
  <EntityType Name="ReportData">
    <Key>
      <PropertyRef Name="ReportDataID" />
    </Key>
    <Property Name="ReportDataID" Type="Int32" Nullable="false" annotation:StoreGeneratedPattern="Identity" />
