      </Dependent>
    </ReferentialConstraint>
  </Association>
  <Association Name="FK_EconomicData_Regions">
    <End Role="Regions" Type="Self.Region" Multiplicity="1">
      <OnDelete Action="Cascade" />
    </End>
    <End Role="EconomicData" Type="Self.EconomicData" Multiplicity="*" />
    <ReferentialConstraint>
      <Principal Role="Regions">
        <PropertyRef Name="RegionID" />
      </Principal>
      <Dependent Role="EconomicData">
        <PropertyRef Name="RegionID" />
      </Dependent>
    </ReferentialConstraint>
  </Association>
  <Association Name="FK_Reports_CreatedBy">
    <End Role="Employees" Type="Self.Employee" Multiplicity="1" />
