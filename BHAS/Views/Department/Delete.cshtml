@model BHAS.DbFirst.Department
@{
    ViewBag.Title = "Obriši odjel";
}

<h2>Potvrda brisanja</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="alert alert-warning">
    <strong>Upozorenje!</strong> Da li ste sigurni da želite obrisati ovaj odjel?
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Naziv odjela</dt>
            <dd class="col-sm-8">@Model.DepartmentName</dd>

            <dt class="col-sm-4">Šifra odjela</dt>
            <dd class="col-sm-8">@Model.DepartmentCode</dd>

            <dt class="col-sm-4">Budžet</dt>
            <dd class="col-sm-8">@Model.Budget.ToString("N2")</dd>
        </dl>
    </div>
</div>

@using (Html.BeginForm("Delete", "Department", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div style="margin-top: 15px;">
        <input type="submit" value="Da, obriši" class="btn btn-danger" />
        @Html.ActionLink("Odustani", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}
