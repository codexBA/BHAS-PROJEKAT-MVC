@model BHAS.DbFirst.Region
@{
    ViewBag.Title = "Obriši regiju";
}

<h2>Potvrda brisanja</h2>
<div class="alert alert-warning"><strong>Upozorenje!</strong> Ova akcija je nepovratna.</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-5">Naziv regije</dt><dd class="col-sm-7">@Model.RegionName</dd>
            <dt class="col-sm-5">Šifra</dt><dd class="col-sm-7">@Model.RegionCode</dd>
            <dt class="col-sm-5">Stanovništvo</dt><dd class="col-sm-7">@Model.Population.ToString("N0")</dd>
        </dl>
    </div>
</div>

@using (Html.BeginForm("Delete", "Region", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div style="margin-top: 15px;">
        <input type="submit" value="Da, obriši" class="btn btn-danger" />
        @Html.ActionLink("Odustani", "Index", null, new { @class = "btn btn-secondary" })
    </div>
}
