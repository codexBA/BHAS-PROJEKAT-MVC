@model List<BHAS.DbFirst.Employee>

@{
    ViewBag.Title = "Pretraga zaposlenika";
}

<h2>Pretraga zaposlenika</h2>

@using (Html.BeginForm("SearchEmployees","StoredProc",FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-3">
            @* drop-down *@
            <label class="form-label">Odjel</label>
            @Html.DropDownList("deptId", (SelectList)ViewBag.DepartmentID, "-- odaberi odjel --", new { @class = "form-control" })
        </div>

        <div class="col-md-2">
            @* min. plata *@
            <label class="form-label">Min. plata</label>
            <input type="number" name="min" id="min" value="@Request.QueryString["min"]" 
                   class="form-control" placeholder="npr. 100" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Max. plata</label>
            <input type="number" name="max" id="max" value="@Request.QueryString["max"]" 
                   class="form-control" placeholder="npr. 15000" />
        </div>

        <div class="col-md-2">
            <button type="submit" 
                    class="btn btn-primary">Pretraži</button>
        </div>
    </div>
}

<table class="table table-bordered table-hover table-striped">
    <thead class="table-dark">
        <tr>
            <th>Ime</th>
            <th>Prezime</th>
            <th>JMBG</th>
            <th>Pozicija</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.FirstName</td>
                <td>@emp.LastName</td>
                <td>@emp.JMBG</td>
                <td>@emp.Position</td>
                <td>@emp.Email</td>
                <td>
                    @Html.ActionLink("Detalji", "Details", "Employee",
                                        new { id = emp.EmployeeID },
                                        new { @class = "btn btn-sm btn-info" })

                    @Html.ActionLink("Uredi", "Edit", "Employee",
                                        new { id = emp.EmployeeID },
                                        new { @class = "btn btn-sm btn-primary" })
                </td>
            </tr>
        }
    </tbody>
</table>